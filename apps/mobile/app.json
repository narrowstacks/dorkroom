{
  "expo": {
    "name": "Dorkroom",
    "slug": "dorkroom",
    "scheme": "dorkroom",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "art.dorkroom.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "26.0"
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Dorkroom uses the camera to meter the light in your scene."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e81d817d-4794-41d4-a2da-e1564e7147be"
      }
    },
    "owner": "narrowstacks-org"
  }
}
